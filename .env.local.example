# このファイルをコピーして「.env.local」を作り、値を埋めてください。
# 値の取得場所: Supabase → Project Settings → API / Database
# ※ .env.local は絶対に Git にコミットしないこと（.gitignore 登録済み）

# クライアントからも参照するもの（公開されてよい情報）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サーバー側だけで使う秘密情報（絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle が使うDB接続URL（Project Settings → Database → Connection string）
DATABASE_URL=

# 将来のクラウド移行に備えた切替スイッチ（今は supabase 固定）
STORAGE_PROVIDER=supabase

# AI機能の切替スイッチ（none=無効。導入手順は docs/06-ai-integration-guide.md）
AI_PROVIDER=none
# AI_PROVIDER=anthropic にする場合に必要（Claude APIキー）
# ANTHROPIC_API_KEY=
